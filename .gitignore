# ============================================================
# finrisk-360  —  Python + Node + Terraform .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
*.sage.py
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.mypy_cache/
.ruff_cache/
.pytype/
cython_debug/

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
package-lock.json
yarn.lock

# ── Terraform ────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── dbt ──────────────────────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/

# ── Airflow ──────────────────────────────────────────────────
airflow/logs/
airflow/plugins/__pycache__/

# ── Data & Artifacts (never commit raw data) ─────────────────
data/
*.csv
*.parquet
*.json.gz
*.avro
!**/fixtures/*.json
!**/fixtures/*.csv

# ── Compiled / Bytecode ─────────────────────────────────────
*.class
*.dll
*.exe
*.o
*.out

# ── Jupyter Notebooks checkpoints ────────────────────────────
.ipynb_checkpoints/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
