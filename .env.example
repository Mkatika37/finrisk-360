# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=your_account_id_here

# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=FINRISK360
SNOWFLAKE_WAREHOUSE=FINRISK_WH
SNOWFLAKE_SCHEMA=ANALYTICS

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOANS=loan-applications
KAFKA_TOPIC_RATES=mortgage-rates
KAFKA_TOPIC_MACRO=macro-indicators

# API Keys
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
CENSUS_API_KEY=your_census_api_key_here

# AWS S3 Buckets
S3_RAW_BUCKET=finrisk360-raw-your_account_id
S3_SILVER_BUCKET=finrisk360-silver-your_account_id
S3_GOLD_BUCKET=finrisk360-gold-your_account_id

# AWS Kinesis
KINESIS_STREAM_NAME=finrisk360-stream
KINESIS_REGION=us-east-1

# AWS SNS
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:your_account:finrisk360-alerts

# Airflow
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# Grafana
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin
