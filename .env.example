# ============================================================
# finrisk-360  —  Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# NEVER commit the .env file to version control.
# ============================================================

# ── External Data-Source API Keys ────────────────────────────
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
CENSUS_API_KEY=your_census_api_key_here

# ── AWS Credentials ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# ── Snowflake ────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_snowflake_account_here
SNOWFLAKE_USER=your_snowflake_user_here
SNOWFLAKE_PASSWORD=your_snowflake_password_here
SNOWFLAKE_DATABASE=FINRISK_360
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=PUBLIC

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Alerting ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:finrisk-alerts
